# Bounty-localnet configuration. Copy to `.env` and edit.
#
# After changing any value below, run ./reset.sh — init.sh hashes these and
# refuses to start a network whose topology no longer matches what was
# generated.

# Number of validator nodes to launch (1..8). The compose file pre-defines
# validator0..validator7; if you change this, also update COMPOSE_PROFILES
# below to match (`min<NUM_VALIDATORS>`, omit it for NUM_VALIDATORS=1).
NUM_VALIDATORS=4

# Number of shards in the localnet's shard layout.
NUM_SHARDS=1

# Stake distribution preset:
#   uniform - all validators stake equally (default; matches `neard localnet`)
#   skewed  - the lexicographically smallest validator (typically node0) gets
#             7x the base stake; total supply is preserved by transferring
#             from that account's unlocked balance.
STAKE_DISTRIBUTION=uniform

# Chain id baked into genesis. Reporters writing repros against this network
# should hard-code the same value.
CHAIN_ID=localnet

# Compose profiles enabling the right number of validator services.
# Keep in sync with NUM_VALIDATORS:
#   NUM_VALIDATORS=1 -> COMPOSE_PROFILES=
#   NUM_VALIDATORS=2 -> COMPOSE_PROFILES=min2
#   NUM_VALIDATORS=3 -> COMPOSE_PROFILES=min3
#   NUM_VALIDATORS=4 -> COMPOSE_PROFILES=min4
#   ...
#   NUM_VALIDATORS=8 -> COMPOSE_PROFILES=min8
COMPOSE_PROFILES=min4
