# Bounty-localnet configuration. Copy to `.env` and edit.
# After changing any value, run ./reset.sh — init.sh hashes these and
# refuses to start a mismatched network.

# Validator count (1..8). Keep COMPOSE_PROFILES below in sync.
NUM_VALIDATORS=4

# Number of shards in the localnet's shard layout.
NUM_SHARDS=1

# Chain id baked into genesis; hard-code the same value in your repro.
CHAIN_ID=localnet

# Must be min<NUM_VALIDATORS> (empty for NUM_VALIDATORS=1) — init.sh fails
# loudly on a mismatch. `just bounty-localnet` derives this automatically.
COMPOSE_PROFILES=min4
